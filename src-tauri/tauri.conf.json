{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Plano de Corte",
  "version": "0.1.0",
  "identifier": "com.plano.corte",
  "build": {
    "frontendDist": "../frontend/dist",
    "beforeDevCommand": "npm run dev --prefix frontend",
    "beforeBuildCommand": "npm run build --prefix frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Plano de Corte",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["../icon.ico", "../icon.png"]
  }
}
