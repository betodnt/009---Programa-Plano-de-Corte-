{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug ControleCorteDobra (MinGW)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build_mingw/ControleCorteDobra.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "Path",
          "value": "C:\\Qt\\6.10.2\\mingw_64\\bin;C:\\Qt\\Tools\\mingw1310_64\\bin;${env:Path}"
        }
      ],
      "externalConsole": true,
      "MIMode": "gdb",
      "miDebuggerPath": "C:\\Qt\\Tools\\mingw1310_64\\bin\\gdb.exe",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
